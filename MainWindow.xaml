<Window x:Class="CyberChatbotGUI_st10448877_POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberChatbotGUI_st10448877_POE"
        mc:Ignorable="d"
        Title="Cybersecurity Chatbot"
        Height="500"
        Width="850"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F2F2F2" Margin="10">

        <TextBlock Text="Cybersecurity Awareness Chatbot"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"
                   Foreground="#2C3E50"/>

        <ListBox x:Name="chatHistory"
                 Margin="10,60,10,80"
                 Background="White"
                 FontSize="14"
                 FontFamily="Consolas"
                 Padding="10"
                 BorderBrush="Gray"
                 BorderThickness="1"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <TextBox x:Name="userInput"
                 Height="35"
                 FontSize="14"
                 Margin="10,0,100,20"
                 VerticalAlignment="Bottom"
                 Padding="5"/>

        <Button Content="Send"
                Width="80"
                Height="35"
                Margin="0,0,10,20"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Click="Send_Click"/>
    </Grid>
</Window>
